<Window x:Class="Naveen_Sir.ScreenSourceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screen Source"
        Width="560"
        Height="360"
        MinWidth="520"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        Background="#111722">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Configure screen sharing source"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="#EAF0FF"
                   Margin="0,0,0,10" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <RadioButton x:Name="EntireScreenRadio"
                         Content="Entire screen"
                         Foreground="#D9E6FF"
                         GroupName="source"
                         Margin="0,0,18,0"
                         Checked="OnModeChanged" />
            <RadioButton x:Name="SpecificWindowRadio"
                         Content="Specific window"
                         Foreground="#D9E6FF"
                         GroupName="source"
                         Checked="OnModeChanged" />
        </StackPanel>

        <Border Grid.Row="2"
                Background="#0B121C"
                BorderBrush="#304058"
                BorderThickness="1"
                CornerRadius="10"
                Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel>
                    <TextBlock Text="Window target"
                               Foreground="#BED1F2"
                               VerticalAlignment="Center" />
                    <Button Content="Refresh"
                            Width="90"
                            DockPanel.Dock="Right"
                            Margin="10,0,0,0"
                            Click="OnRefresh" />
                </DockPanel>

                <ListBox x:Name="WindowList"
                         Grid.Row="1"
                         Margin="0,10,0,0"
                         DisplayMemberPath="DisplayLabel"
                         Background="#0A111B"
                         Foreground="#DDE9FF"
                         BorderBrush="#334862"
                         BorderThickness="1" />
            </Grid>
        </Border>

        <DockPanel Grid.Row="3" Margin="0,12,0,0" LastChildFill="False">
            <TextBlock x:Name="HintText"
                       Foreground="#97AFD0"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left" />
            <Button Content="Cancel" Width="100" Margin="0,0,8,0" Click="OnCancel" />
            <Button Content="Save" Width="100" Click="OnSave" />
        </DockPanel>
    </Grid>
</Window>