<Window x:Class="Naveen_Sir.LoadoutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings"
    Height="590"
    Width="1120"
        MinHeight="520"
        MinWidth="900"
        WindowStartupLocation="CenterOwner"
    Background="#111722">
    <Window.Resources>
        <SolidColorBrush x:Key="DialogSurfaceBrush" Color="#0B121B" />
        <SolidColorBrush x:Key="DialogPanelBrush" Color="#111722" />
        <SolidColorBrush x:Key="DialogBorderBrush" Color="#2A3850" />
        <SolidColorBrush x:Key="DialogTextBrush" Color="#D7E2F7" />
        <SolidColorBrush x:Key="DialogMutedBrush" Color="#B4C6E4" />

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#E7EFFD" />
            <Setter Property="Background" Value="#1A2639" />
            <Setter Property="BorderBrush" Value="#3F577D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0E1724" />
            <Setter Property="Foreground" Value="{StaticResource DialogTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DialogBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0E1724" />
            <Setter Property="Foreground" Value="{StaticResource DialogTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DialogBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#162233" />
            <Setter Property="Foreground" Value="#DAE8FF" />
            <Setter Property="BorderBrush" Value="#324662" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="#0B121B" />
            <Setter Property="Foreground" Value="{StaticResource DialogTextBrush}" />
            <Setter Property="BorderBrush" Value="#23344D" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Manage provider settings"
                   Foreground="#E8EFFD"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10" />

        <DataGrid x:Name="LoadoutsGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  Background="#0B121B"
                  Foreground="#D7E2F7"
                  BorderBrush="#2A3850"
                  BorderThickness="1"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Single"
                  SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="1.1*" />
                <DataGridTextColumn Header="Endpoint" Binding="{Binding Endpoint, UpdateSourceTrigger=PropertyChanged}" Width="2.4*" />
                <DataGridTextColumn Header="API Key" Binding="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" Width="1.8*" />
                <DataGridTextColumn Header="Default Model" Binding="{Binding ModelId, UpdateSourceTrigger=PropertyChanged}" Width="1.05*" />
                <DataGridTextColumn Header="Chip Model" Binding="{Binding ChipModelId, UpdateSourceTrigger=PropertyChanged}" Width="1.05*" />
                <DataGridTextColumn Header="Topic Model" Binding="{Binding TopicModelId, UpdateSourceTrigger=PropertyChanged}" Width="1.05*" />
                <DataGridTextColumn Header="Temp" Binding="{Binding Temperature, UpdateSourceTrigger=PropertyChanged}" Width="0.6*" />
                <DataGridTextColumn Header="Max Tokens" Binding="{Binding MaxTokens, UpdateSourceTrigger=PropertyChanged}" Width="0.8*" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Add" Width="90" Margin="0,0,8,0" Click="OnAdd" />
                <Button Content="Fork" Width="90" Margin="0,0,8,0" Click="OnFork" />
                <Button Content="Delete" Width="90" Click="OnDelete" />
                <TextBlock Text="Active:" Foreground="#B4C6E4" VerticalAlignment="Center" Margin="18,0,8,0" />
                <ComboBox x:Name="ActiveLoadoutCombo"
                          Width="260"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Cancel" Width="110" Margin="0,0,8,0" Click="OnCancel" />
                <Button Content="Save" Width="110" Click="OnSave" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>