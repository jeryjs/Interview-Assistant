<Window x:Class="Naveen_Sir.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Interview Helper"
        Height="780"
        Width="1280"
        MinHeight="640"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#0C0F14" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#111A27" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#283A53" />
        <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#1A2536" />
        <SolidColorBrush x:Key="ControlBorderBrush" Color="#3B5277" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#ECF3FF" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#A6BAD7" />
        <SolidColorBrush x:Key="ChipSurfaceBrush" Color="#203553" />
        <SolidColorBrush x:Key="ChipBorderBrush" Color="#4A71A8" />
        <SolidColorBrush x:Key="TranscriptSurfaceBrush" Color="#0E1623" />

        <Style TargetType="Button" x:Key="ControlButtonStyle">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToggleButton" x:Key="ControlToggleStyle">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2D4D78" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="#7EA8E5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChipButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource ChipSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ChipBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="10" CornerRadius="14" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1">
        <Grid Margin="12,10,12,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12" MouseLeftButtonDown="OnDragHandleMouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Interview Assistant"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="ProviderStatusText"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12"
                               Margin="0,2,0,0" />
                </StackPanel>

                <Grid Grid.Column="1" Margin="10,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="StatusText"
                               Grid.Column="0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />

                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                        <ToggleButton x:Name="PauseToggle" Style="{StaticResource ControlToggleStyle}" Content="⏸" ToolTip="Pause all" Checked="OnPauseToggleChanged" Unchecked="OnPauseToggleChanged" />
                        <ToggleButton x:Name="MicToggle" Style="{StaticResource ControlToggleStyle}" Content="Mic" Checked="OnCaptureToggleChanged" Unchecked="OnCaptureToggleChanged" />
                        <ToggleButton x:Name="SystemToggle" Style="{StaticResource ControlToggleStyle}" Content="System" Checked="OnCaptureToggleChanged" Unchecked="OnCaptureToggleChanged" />
                        <ToggleButton x:Name="ScreenToggle" Style="{StaticResource ControlToggleStyle}" Content="Screen" Checked="OnCaptureToggleChanged" Unchecked="OnCaptureToggleChanged" />
                        <Button x:Name="ScreenSourceButton" Style="{StaticResource ControlButtonStyle}" Content="⚙" Width="34" Padding="0" Click="OnOpenScreenSourceSettings" ToolTip="Screen source settings" />
                        <ToggleButton x:Name="TopmostToggle" Style="{StaticResource ControlToggleStyle}" Content="Pin Top" Checked="OnPinTopToggleChanged" Unchecked="OnPinTopToggleChanged" />
                        <Button Style="{StaticResource ControlButtonStyle}" Content="Loadouts" Click="OnOpenSettings" />
                        <Button Style="{StaticResource ControlButtonStyle}" Content="Clear Chips" Click="OnClearChips" />
                    </WrapPanel>
                </Grid>
            </Grid>

            <Grid Grid.Row="1" Background="Transparent">
                <Border CornerRadius="12"
                        Background="{DynamicResource TranscriptSurfaceBrush}"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="1"
                        Padding="14"
                        Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Recommendations"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12" />

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ChipItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource ChipButtonStyle}" Content="{Binding Text}" Click="OnChipClick" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Width="360"
                        Margin="0,16,16,0"
                        Padding="8"
                        CornerRadius="12"
                        Background="#C0101622"
                        BorderBrush="{DynamicResource PanelBorderBrush}"
                        BorderThickness="1"
                        Panel.ZIndex="12">
                    <Expander x:Name="TranscriptExpander"
                              Foreground="{DynamicResource PrimaryTextBrush}"
                              Header="Live transcript"
                              IsExpanded="False"
                              Expanded="OnTranscriptExpanded"
                              Collapsed="OnTranscriptCollapsed">
                        <ListBox x:Name="TranscriptList"
                                 Height="220"
                                 Margin="0,8,0,0"
                                 Background="#A00A111B"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 BorderBrush="{DynamicResource PanelBorderBrush}"
                                 BorderThickness="1" />
                    </Expander>
                </Border>
            </Grid>
        </Grid>
    </Border>

</Window>
