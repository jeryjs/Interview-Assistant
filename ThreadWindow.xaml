<Window x:Class="Naveen_Sir.ThreadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Topic Thread"
        Width="980"
        Height="760"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#111721">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#172131" BorderBrush="#2A3A51" BorderThickness="0,0,0,1">
            <Grid Margin="12,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="TopicTitleText" Foreground="#F5F8FF" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock x:Name="StatusText" Foreground="#A8BCDC" FontSize="12" />
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Close"
                        Width="92"
                        Height="32"
                        Foreground="#EAF1FF"
                        Background="#2A3850"
                        BorderBrush="#465F86"
                        BorderThickness="1"
                        Click="OnCloseClick" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="ReasoningRow" Height="0" />
                <RowDefinition x:Name="AnswerRow" Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="ReasoningSection"
                    Grid.Row="0"
                    Visibility="Collapsed"
                    BorderBrush="#23354D"
                    BorderThickness="0,0,0,1"
                    Background="#180D1420"
                    Padding="8,4,8,4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Reasoning"
                               Foreground="#95AECE"
                               FontWeight="SemiBold"
                               FontSize="11"
                               Margin="2,0,0,6" />

                    <wpf:WebView2 x:Name="ReasoningView" Grid.Row="1" Margin="0" />
                </Grid>
            </Border>

            <Border Grid.Row="1" Padding="8,6,8,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Final answer"
                               Foreground="#DDEBFF"
                               FontWeight="SemiBold"
                               FontSize="12"
                               Margin="2,0,0,6" />

                    <wpf:WebView2 x:Name="AnswerView" Grid.Row="1" Margin="0" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>